{
  "name": "stablelinq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run deploy-migrations && next build",
    "deploy-migrations": "node scripts/migrate-deploy.mjs",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "test:discord": "tsx scripts/test-discord-phone-status.ts",
    "ensure:webhook": "tsx scripts/ensure-linq-webhook-subscription.ts",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentcash/router": "1.18.0",
    "@agentcash/telemetry": "0.5.4",
    "@linqapp/sdk": "0.28.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@t3-oss/env-nextjs": "0.13.10",
    "@upstash/redis": "^1.36.2",
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@prisma/client-runtime-utils": "^7.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.6",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
