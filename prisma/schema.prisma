generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RecipientWarmth {
  id                          String    @id @default(cuid())
  fromLine                    String
  recipient                   String
  firstOutboundAt             DateTime  @default(now())
  chatId                      String?
  consecutiveUnansweredOutbound Int     @default(0)
  lastInboundAt               DateTime?
  lastOutboundAt              DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@unique([fromLine, recipient])
  @@index([recipient])
  @@index([chatId])
  @@index([fromLine, chatId])
}

model SentMessage {
  id                  String   @id @default(cuid())
  walletAddress       String
  slug                String
  fromLine            String
  recipients          String[]
  chatId              String?
  linqMessageId       String?
  priceUsd            String
  coldRecipientCount  Int      @default(0)
  warmRecipientCount  Int      @default(0)
  messagePreview      String?
  requestBody         Json
  linqResponse        Json?
  createdAt           DateTime @default(now())

  @@index([walletAddress, createdAt(sort: Desc), id(sort: Desc)])
  @@index([walletAddress, chatId])
  @@index([chatId])
  @@index([fromLine, chatId])
  @@index([linqMessageId])
}
